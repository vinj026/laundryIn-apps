# ===================================
# ENVIRONMENT VARIABLES - FRONTEND
# ===================================
# Copy this file to .env.local untuk development
# Untuk production (Vercel), set di Vercel Dashboard > Settings > Environment Variables

# ===================================
# API CONFIGURATION (WAJIB DI PRODUCTION)
# ===================================

# URL lengkap ke backend API Railway (tanpa trailing slash)
# Format: https://<your-railway-app>.up.railway.app/api/v1
# Development: /api (gunakan proxy Nuxt)
# Production: URL lengkap Railway
NUXT_PUBLIC_API_BASE_URL=/api

# WebSocket URL untuk real-time notifications
# Format: wss://<your-railway-app>.up.railway.app/api/v1/ws/connect
# Development: ws://localhost:8080/api/v1/ws/connect
# Production: wss://...railway.app/api/v1/ws/connect
NUXT_PUBLIC_WS_BASE_URL=ws://localhost:8080/api/v1/ws/connect

# ===================================
# BACKEND URL (untuk Vercel Rewrites)
# ===================================

# URL backend Railway tanpa path (hanya domain)
# Digunakan oleh Vercel rewrites di vercel.json
# Development: http://localhost:8080
# Production: https://laundryin-apps-production.up.railway.app
BACKEND_URL=http://localhost:8080

# ===================================
# CONTOH KONFIGURASI PRODUCTION
# ===================================
# Set di Vercel Dashboard:
# NUXT_PUBLIC_API_BASE_URL=https://laundryin-apps-production.up.railway.app/api/v1
# NUXT_PUBLIC_WS_BASE_URL=wss://laundryin-apps-production.up.railway.app/api/v1/ws/connect
# BACKEND_URL=https://laundryin-apps-production.up.railway.app

# ===================================
# CONTOH KONFIGURASI DEVELOPMENT
# ===================================
# .env.local:
# NUXT_PUBLIC_API_BASE_URL=/api
# NUXT_PUBLIC_WS_BASE_URL=ws://localhost:8080/api/v1/ws/connect
# BACKEND_URL=http://localhost:8080
